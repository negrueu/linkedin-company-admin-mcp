# Example environment file. Copy to `.env` and customise.
# There are NO credentials here - LinkedIn login is via persistent browser
# profile (see `linkedin-company-admin-mcp --login`).

# --- Server transport ---
# One of: stdio (default, for Claude Desktop), streamable-http
LINKEDIN_TRANSPORT=stdio

# --- HTTP transport settings (only if LINKEDIN_TRANSPORT=streamable-http) ---
# LINKEDIN_HOST=127.0.0.1
# LINKEDIN_PORT=8765
# LINKEDIN_HTTP_PATH=/mcp

# --- Browser ---
# Run headless (default true). Set to 0 for debugging selector issues.
LINKEDIN_HEADLESS=1
# Custom browser profile directory (default: ~/.linkedin-company-admin/profile)
# LINKEDIN_USER_DATA_DIR=

# --- Logging ---
# One of: DEBUG, INFO (default), WARNING, ERROR
LINKEDIN_LOG_LEVEL=INFO

# --- Tool behavior ---
# Default tool timeout in seconds
LINKEDIN_TOOL_TIMEOUT=60
